---
/** Lists every category with its localized title, linking to its listing. */
import { getCollection } from 'astro:content';
import { localized } from '../../../lib/content';
import { categoryPath } from '../../../lib/routing.mjs';
import { t } from '../../../i18n/ui.mjs';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const categories = await getCollection('categories');
---

<section class="taxonomy">
  <h3>{t(lang, 'sectionCategories')}</h3>
  <ul>
    {
      categories.map((c) => (
        <li>
          <a href={categoryPath(lang, localized(c, lang).slug, 1)}>{localized(c, lang).title}</a>
        </li>
      ))
    }
  </ul>
</section>
