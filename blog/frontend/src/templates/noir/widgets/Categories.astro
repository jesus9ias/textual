---
/** Lists every category with its localized title, linking to its listing. */
import { getCollection } from 'astro:content';
import { localized } from '../../../lib/content';
import { categoryPath } from '../../../lib/routing.mjs';
import { t } from '../../../i18n/ui.mjs';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const categories = await getCollection('categories');
---

<section class="taxonomy">
  <h3>{t(lang, 'sectionCategories')}</h3>
  <ul>
    {
      categories.map((c) => (
        <li>
          <a href={categoryPath(lang, localized(c, lang).slug, 1)}>{localized(c, lang).title}</a>
        </li>
      ))
    }
  </ul>
</section>

<style is:global>
  html[data-template='noir'] .taxonomies .taxonomy {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  html[data-template='noir'] .taxonomies .taxonomy h3 {
    margin: 0 0 0.75rem;
    color: var(--accent);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  html[data-template='noir'] .taxonomies .taxonomy ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  html[data-template='noir'] .taxonomies .taxonomy a {
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
  }
  html[data-template='noir'] .taxonomies .taxonomy a:hover {
    color: var(--accent);
  }
</style>
