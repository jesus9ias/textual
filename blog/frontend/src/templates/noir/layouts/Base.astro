---
/**
 * Dark ("noir") HTML skeleton shared by every page in this template. Owns the
 * <head> SEO surface identically to the default template's Base. The home page
 * passes an `<aside class="taxonomies">` (Categories/Tags/Authors) as part of
 * its slot content; this layout reflows it into a right-hand column purely via
 * CSS grid (`main:has(> .taxonomies)`) — no page markup changes required, so
 * other templates/pages are unaffected.
 */
import { siteUrl } from '../../../lib/site';
import { absoluteUrl, rssPath } from '../../../lib/routing.mjs';
import { t } from '../../../i18n/ui.mjs';
import Menu from '../widgets/Menu.astro';

interface HreflangAlternate {
  hreflang: string;
  href: string;
}

interface Props {
  lang: string;
  title: string;
  description: string;
  /** Absolute path (starts with `/`) of the current page, for the canonical URL. */
  canonicalPath: string;
  hreflang?: HreflangAlternate[];
  /** Absolute URL of the social share image. */
  ogImage?: string;
  /** Page-aware language switcher entries; falls back to language homes. */
  langSwitch?: { lang: string; href: string }[];
}

const { lang, title, description, canonicalPath, hreflang = [], ogImage, langSwitch } = Astro.props;

const canonicalUrl = absoluteUrl(siteUrl, canonicalPath);
const siteTitle = t(lang, 'siteTitle');
const pageTitle = title === siteTitle ? title : `${title} · ${siteTitle}`;
---

<!doctype html>
<html lang={lang} data-template="noir">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {hreflang.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link
      rel="alternate"
      type="application/rss+xml"
      title={t(lang, 'rssTitle')}
      href={absoluteUrl(siteUrl, rssPath(lang))}
    />
  </head>
  <body>
    <Menu lang={lang} langSwitch={langSwitch} />
    <main>
      <slot />
    </main>
    <footer>
      <p>{siteTitle} — {t(lang, 'siteTagline')}</p>
    </footer>
    <style is:global>
      html[data-template='noir'] {
        --max-width: 72ch;
        --sidebar-width: 300px;
        --bg: #0b0b0d;
        --surface: #17171b;
        --surface-raised: #1f1f24;
        --text: #ececef;
        --muted: #9a9aa3;
        --border: #2c2c33;
        --accent: #e0b34d;
      }
      html[data-template='noir'] * {
        box-sizing: border-box;
      }
      html[data-template='noir'] body {
        margin: 0;
        font-family: system-ui, sans-serif;
        line-height: 1.6;
        color: var(--text);
        background: var(--bg);
      }
      html[data-template='noir'] main {
        max-width: calc(var(--max-width) + var(--sidebar-width) + 2.5rem);
        margin: 0 auto;
        padding: 1.5rem;
      }
      /* Only reflows when the home page's taxonomy aside is present; every
         other page (post, listings) keeps a single reading column. */
      html[data-template='noir'] main:has(> .taxonomies) {
        display: grid;
        grid-template-columns: minmax(0, 1fr) var(--sidebar-width);
        align-items: start;
        gap: 2.5rem;
        max-width: calc(var(--max-width) + var(--sidebar-width) + 2.5rem);
      }
      html[data-template='noir'] main:has(> .taxonomies) > .taxonomies {
        grid-column: 2;
        grid-row: 1 / span 3;
      }
      html[data-template='noir'] main:not(:has(> .taxonomies)) {
        max-width: var(--max-width);
      }
      html[data-template='noir'] a {
        color: var(--accent);
      }
      html[data-template='noir'] img {
        max-width: 100%;
        height: auto;
      }
      html[data-template='noir'] footer {
        max-width: var(--max-width);
        margin: 2rem auto;
        padding: 1.5rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
      }
    </style>
  </body>
</html>
