# blog/frontend build-time environment.
#
# Copy to `.env` (git-ignored). The real production value is environment-specific
# and injected here / in CI — never hardcoded in committed source.

# Absolute public site URL (no trailing slash), e.g. https://blog.example.com
PUBLIC_SITE_URL=

# Active template under src/templates/. Selected at build time; not per-request.
PUBLIC_TEMPLATE=default
