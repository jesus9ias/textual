# blog/infra environment configuration.
#
# Copy this file to `.env` and fill in every value. `.env` is git-ignored and
# is the ONLY place environment-specific / sensitive values live — nothing here
# is ever hardcoded in source. All values are read and validated in lib/env.ts.

# Name of the whole stack. Drives the CloudFormation stack name and the prefix
# of every auto-generated resource name, so the same project can be deployed as
# multiple independent stacks (one .env per subdomain / fork). Must start with a
# letter; letters, digits and hyphens only, e.g. textual-blog.
STACK_NAME=textual

# Apex domain of the existing Route 53 hosted zone (e.g. example.com).
DOMAIN_NAME=

# Optional subdomain the blog is served under (e.g. blog). Leave empty to serve
# the site on the apex domain itself.
SUBDOMAIN=

# Id of the EXISTING Route 53 hosted zone (referenced, never created).
HOSTED_ZONE_ID=

# ARN of the ACM certificate covering the site domain. Must be issued in
# us-east-1 (CloudFront requirement).
CERTIFICATE_ARN=

# Default language code. Baked into the root-redirect CloudFront Function at
# synth time: the exact URI "/" 301-redirects to "/{DEFAULT_LANG}/". Lowercase
# language code, e.g. es.
DEFAULT_LANG=

# 12-digit AWS account id the stack deploys into.
AWS_ACCOUNT_ID=

# Deploy region. Must be us-east-1 — the entire stack deploys there so the
# CloudFront ACM certificate needs no cross-region reference.
AWS_REGION=us-east-1

# Optional named AWS CLI/SDK profile to use for `cdk deploy`.
AWS_PROFILE=
