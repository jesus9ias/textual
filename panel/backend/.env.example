# panel/backend environment configuration.
#
# Copy this file to `.env` and point it at a local checkout of the blog. `.env`
# is git-ignored and is the only place these environment-specific paths live.
# The panel backend runs on localhost only and is never deployed.

# Path to blog/frontend/src/content — holds posts/ and the categories/tags/
# authors JSON collections (per the Domain Model).
BLOG_CONTENT_PATH=../../blog/frontend/src/content

# Path to blog/frontend/src — holds site.config.json.
BLOG_CONFIG_PATH=../../blog/frontend/src

# Localhost port for the mini backend.
PANEL_PORT=4321
